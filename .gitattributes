# Set default behavior to handle line endings automatically
* text=auto

# Explicitly declare text files you want to always be LF or CRLF
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.env text eol=lf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.wav binary
*.pdf binary
